#!/bin/sh
set -eu

if [ "${1:-}" != "--run" ]; then
  branch="$(git symbolic-ref --quiet --short HEAD 2>/dev/null || true)"

  if [ "$branch" = "main" ]; then
    echo "Direct commits on main are blocked. Create a feature branch and open a PR." >&2
    exit 1
  fi

  exec bun run precommit
fi

export RAWENGINE_COMPACT_MAX_CHARS="${RAWENGINE_COMPACT_MAX_CHARS:-1800}"
export RAWENGINE_COMPACT_MAX_LINES="${RAWENGINE_COMPACT_MAX_LINES:-16}"
export RAWENGINE_COMPACT_HEAD_LINES="${RAWENGINE_COMPACT_HEAD_LINES:-5}"
export RAWENGINE_COMPACT_TAIL_LINES="${RAWENGINE_COMPACT_TAIL_LINES:-8}"

bun run lint:fix
git add -u

tmpdir="$(mktemp -d "${TMPDIR:-/tmp}/rapidraw-precommit.XXXXXX")"
trap 'rm -rf "$tmpdir"' EXIT INT TERM

pids=""

run_gate() {
  label="$1"
  shift
  log="$tmpdir/$label.log"
  ("$@" >"$log" 2>&1) &
  pids="$pids $!:$label"
}

run_gate lint bun run lint
run_gate format bun run format:check
run_gate typecheck bun run typecheck
run_gate test bun run test:unit
run_gate unsafe-casts bun tests/integration/checks/check-unsafe-casts.ts
run_gate rustfmt bun run check:rust:fmt
run_gate rust-clippy bun run check:rust:clippy
run_gate schema bun run check:schema
run_gate bundle bun run check:bundle
run_gate actions bun run check:actions
run_gate action-pins bun tests/integration/checks/check-github-action-pins.ts
run_gate security bun run check:security
run_gate browser-harness bun run check:browser-harness
run_gate tauri-commands bun tests/integration/checks/tauri/check-tauri-command-registration.ts
run_gate tauri-schemas bun tests/integration/checks/tauri/check-tauri-schema-validation.ts
run_gate script-types bun tests/integration/checks/check-script-type-coverage.ts
run_gate rust-cfg bun tests/integration/checks/check-rust-platform-cfg-dead-code.ts
run_gate native-contract-boundary bun tests/integration/checks/check-native-contract-boundary.ts
run_gate perf-smoke bun scripts/checks/ci/check-performance-smoke.ts
run_gate i18n bun scripts/ci/run-compact-command.ts --label i18n:lint -- bunx i18next-cli lint
run_gate i18n-extract bun scripts/ci/run-compact-command.ts --label i18n:extract -- bunx i18next-cli extract --ci --dry-run
run_gate unused-deps bun scripts/ci/run-compact-command.ts --label unused-deps -- bunx knip --config knip.jsonc --dependencies --reporter compact
run_gate docs bun run check:docs

failed=0
for entry in $pids; do
  pid="${entry%%:*}"
  label="${entry#*:}"
  log="$tmpdir/$label.log"
  if wait "$pid"; then
    echo "$label ok"
  else
    failed=1
    echo "$label failed" >&2
    tail -n "${RAWENGINE_COMPACT_TAIL_LINES:-8}" "$log" >&2
  fi
done

exit "$failed"
