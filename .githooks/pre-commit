#!/bin/sh
set -eu

branch="$(git symbolic-ref --quiet --short HEAD 2>/dev/null || true)"

if [ "$branch" = "main" ]; then
  echo "Direct commits on main are blocked. Create a feature branch and open a PR." >&2
  exit 1
fi

export RAWENGINE_COMPACT_MAX_CHARS="${RAWENGINE_COMPACT_MAX_CHARS:-1800}"
export RAWENGINE_COMPACT_MAX_LINES="${RAWENGINE_COMPACT_MAX_LINES:-16}"
export RAWENGINE_COMPACT_HEAD_LINES="${RAWENGINE_COMPACT_HEAD_LINES:-5}"
export RAWENGINE_COMPACT_TAIL_LINES="${RAWENGINE_COMPACT_TAIL_LINES:-8}"

staged_files="$(git diff --cached --name-only --diff-filter=ACMR)"

bun lint-staged --quiet --concurrent false
bun run check:lint
bun run check:external-editor-missing-launcher

if printf '%s\n' "$staged_files" | grep -Eq '^(src-tauri/.*\.rs|src-tauri/Cargo\.(toml|lock)|\.cargo/.*|rust-toolchain\.toml)$'; then
  bun run check:rust:fmt
  bun run check:rust:check
  bun run check:rust:clippy
  bun run check:rust:test
fi

if printf '%s\n' "$staged_files" | grep -Eq '^\.github/workflows/.*\.ya?ml$'; then
  bun run check:actions:lint
  bun run check:workflow-policy
fi
