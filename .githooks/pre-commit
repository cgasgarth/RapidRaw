#!/bin/sh
set -eu

branch="$(git symbolic-ref --quiet --short HEAD 2>/dev/null || true)"

if [ "$branch" = "main" ]; then
  echo "Direct commits on main are blocked. Create a feature branch and open a PR." >&2
  exit 1
fi

export RAWENGINE_COMPACT_MAX_CHARS="${RAWENGINE_COMPACT_MAX_CHARS:-3000}"
export RAWENGINE_COMPACT_MAX_LINES="${RAWENGINE_COMPACT_MAX_LINES:-24}"
export RAWENGINE_COMPACT_HEAD_LINES="${RAWENGINE_COMPACT_HEAD_LINES:-6}"
export RAWENGINE_COMPACT_TAIL_LINES="${RAWENGINE_COMPACT_TAIL_LINES:-14}"

bun scripts/check-staged-files.mjs
