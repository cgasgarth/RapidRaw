#!/bin/sh
set -eu

branch="$(git symbolic-ref --quiet --short HEAD 2>/dev/null || true)"

if [ "$branch" = "main" ]; then
  echo "Direct commits on main are blocked. Create a feature branch and open a PR." >&2
  exit 1
fi

export RAWENGINE_COMPACT_MAX_CHARS="${RAWENGINE_COMPACT_MAX_CHARS:-1800}"
export RAWENGINE_COMPACT_MAX_LINES="${RAWENGINE_COMPACT_MAX_LINES:-16}"
export RAWENGINE_COMPACT_HEAD_LINES="${RAWENGINE_COMPACT_HEAD_LINES:-5}"
export RAWENGINE_COMPACT_TAIL_LINES="${RAWENGINE_COMPACT_TAIL_LINES:-8}"

staged_files="$(git diff --cached --name-only --diff-filter=ACMR)"

bun lint-staged --quiet --concurrent false
bun run check:lint
bun run check:external-editor-missing-launcher

if [ -n "$staged_files" ]; then
  macos_smoke_files="$(mktemp)"
  macos_smoke_outputs="$(mktemp)"
  printf '%s\n' "$staged_files" > "$macos_smoke_files"
  bun tests/integration/checks/check-ci-classify-macos-smoke.ts --files "$macos_smoke_files" > "$macos_smoke_outputs"
  if grep -q '^macos_smoke_decision=unclassified-fail-closed$' "$macos_smoke_outputs"; then
    echo "Unclassified path requires explicit CI routing before merge." >&2
    sed -n '/^macos_smoke_required_paths<<EOF_macos_smoke_required_paths$/,/^EOF_macos_smoke_required_paths$/p' "$macos_smoke_outputs" >&2
    rm -f "$macos_smoke_files" "$macos_smoke_outputs"
    exit 1
  fi
  rm -f "$macos_smoke_files" "$macos_smoke_outputs"
fi

if printf '%s\n' "$staged_files" | grep -Eq '(^|/)(package\.json|bun\.lock|tsconfig[^/]*\.json)$|\.tsx?$'; then
  bun run check:types
fi

if printf '%s\n' "$staged_files" | grep -Eq '^(src/|tests/integration/checks/check-browser-tauri-harness\.ts$|scripts/capture-visual-smoke\.ts$|scripts/lib/visual-smoke-proofs\.ts$|index\.html$|vite\.config\.ts$|package\.json$|bun\.lock$)'; then
  bun run check:visual-smoke:pr
  bun run check:browser-tauri-harness
fi

if printf '%s\n' "$staged_files" | grep -Eq '^(src-tauri/.*\.rs|src-tauri/Cargo\.(toml|lock)|\.cargo/.*|rust-toolchain\.toml)$'; then
  bun run check:rust:fmt
  bun run check:rust:check
  bun run check:rust:clippy
  bun run check:rust:test
fi

if printf '%s\n' "$staged_files" | grep -Eq '^\.github/workflows/.*\.ya?ml$'; then
  bun run check:actions:lint
  bun run check:workflow-policy
fi
