#!/bin/sh
set -eu

branch="$(git symbolic-ref --quiet --short HEAD 2>/dev/null || true)"

if [ "$branch" = "main" ]; then
  echo "Direct commits on main are blocked. Create a feature branch and open a PR." >&2
  exit 1
fi

export RAWENGINE_COMPACT_MAX_CHARS="${RAWENGINE_COMPACT_MAX_CHARS:-1800}"
export RAWENGINE_COMPACT_MAX_LINES="${RAWENGINE_COMPACT_MAX_LINES:-16}"
export RAWENGINE_COMPACT_HEAD_LINES="${RAWENGINE_COMPACT_HEAD_LINES:-5}"
export RAWENGINE_COMPACT_TAIL_LINES="${RAWENGINE_COMPACT_TAIL_LINES:-8}"

staged_files="$(git diff --cached --name-only --diff-filter=ACMR)"

bun lint-staged --quiet --concurrent false

if printf '%s\n' "$staged_files" | grep -Eq '^(AGENTS\.md|docs/|.*\.md$)'; then
  bun run docs:check
fi

if printf '%s\n' "$staged_files" | grep -Eq '^(src/|i18next\.config\.ts$|package\.json$|bun\.lock$)'; then
  bun run check:i18n
fi

if printf '%s\n' "$staged_files" | grep -Eq '^(src/|scripts/|tests/|eslint\.config\.js|biome\.json|package\.json|bun\.lock|tsconfig[^/]*\.json$)'; then
  bun run check:lint-escapes
fi

if printf '%s\n' "$staged_files" | grep -Eq '^eslint\.config\.js$'; then
  bun run check:eslint-gaps
fi

if printf '%s\n' "$staged_files" | grep -Eq '^biome\.json$'; then
  bun run check:lint
fi

if printf '%s\n' "$staged_files" | grep -Eq '^(knip\.jsonc|package\.json|bun\.lock|tsconfig[^/]*\.json$)'; then
  bun run check:unused-deps
fi

if [ -n "$staged_files" ]; then
  macos_smoke_files="$(mktemp)"
  macos_smoke_outputs="$(mktemp)"
  printf '%s\n' "$staged_files" > "$macos_smoke_files"
  bun tests/integration/checks/check-ci-classify-macos-smoke.ts --files "$macos_smoke_files" > "$macos_smoke_outputs"
  if grep -q '^macos_smoke_decision=unclassified-fail-closed$' "$macos_smoke_outputs"; then
    echo "Unclassified path requires explicit CI routing before merge." >&2
    sed -n '/^macos_smoke_required_paths<<EOF_macos_smoke_required_paths$/,/^EOF_macos_smoke_required_paths$/p' "$macos_smoke_outputs" >&2
    rm -f "$macos_smoke_files" "$macos_smoke_outputs"
    exit 1
  fi
  rm -f "$macos_smoke_files" "$macos_smoke_outputs"
fi

if printf '%s\n' "$staged_files" | grep -Eq '(^|/)(package\.json|bun\.lock|tsconfig[^/]*\.json)$|\.tsx?$'; then
  bun run check:types
  bun run check:unsafe-casts
fi

if printf '%s\n' "$staged_files" | grep -Eq '^(packages/rawengine-schema/|fixtures/|samples/)'; then
  bun run schema:check
  bun run schema:command-bus
  bun run schema:contract-gate
fi

if printf '%s\n' "$staged_files" | grep -Eq '^(src-tauri/.*\.rs|src-tauri/Cargo\.(toml|lock)|\.cargo/.*|rust-toolchain\.toml)$'; then
  bun run check:rust:fmt
  bun run check:rust:platform-cfg-dead-code
fi

if printf '%s\n' "$staged_files" | grep -Eq '^(\.github/|tests/integration/checks/check-(actions|workflow|compact|rust-feature|schema-contract)|scripts/compact-output\.ts|scripts/run-compact-command\.ts|scripts/run-compact-checks\.ts)'; then
  bun run check:actions
  bun run check:action-pins
fi

if printf '%s\n' "$staged_files" | grep -Eq '^(\.githooks/pre-commit|tests/integration/checks/check-precommit-fast-path\.ts|package\.json)$'; then
  bun run check:precommit-fast-path
fi
