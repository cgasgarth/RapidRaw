[
  {
    "id": "opacity-clamps-to-range",
    "initialLayers": [
      { "id": "tone", "name": "Tone Balance", "opacity": 100, "visible": true },
      { "id": "sky", "name": "Sky Recover", "opacity": 80, "visible": true }
    ],
    "operations": [{ "type": "setOpacity", "layerId": "sky", "opacity": 144 }],
    "expectedLayers": [
      { "id": "tone", "name": "Tone Balance", "opacity": 100, "visible": true },
      { "id": "sky", "name": "Sky Recover", "opacity": 100, "visible": true }
    ]
  },
  {
    "id": "visibility-and-reorder",
    "initialLayers": [
      { "id": "tone", "name": "Tone Balance", "opacity": 100, "visible": true },
      { "id": "skin", "name": "Skin Uniformity", "opacity": 65, "visible": true },
      { "id": "sky", "name": "Sky Recover", "opacity": 80, "visible": true }
    ],
    "operations": [
      { "type": "setVisibility", "layerId": "skin", "visible": false },
      { "type": "move", "layerId": "sky", "direction": "up" }
    ],
    "expectedLayers": [
      { "id": "tone", "name": "Tone Balance", "opacity": 100, "visible": true },
      { "id": "sky", "name": "Sky Recover", "opacity": 80, "visible": true },
      { "id": "skin", "name": "Skin Uniformity", "opacity": 65, "visible": false }
    ],
    "expectedRenderPlan": [
      {
        "adjustmentKeys": ["sharpnessThreshold"],
        "layerId": "tone",
        "name": "Tone Balance",
        "opacity": 100,
        "opacityFraction": 1,
        "subMaskCount": 0
      },
      {
        "adjustmentKeys": ["sharpnessThreshold"],
        "layerId": "sky",
        "name": "Sky Recover",
        "opacity": 80,
        "opacityFraction": 0.8,
        "subMaskCount": 0
      }
    ]
  },
  {
    "id": "duplicate-and-delete",
    "initialLayers": [
      { "id": "tone", "name": "Tone Balance", "opacity": 100, "visible": true },
      { "id": "skin", "name": "Skin Uniformity", "opacity": 65, "visible": true }
    ],
    "operations": [
      { "type": "duplicate", "layerId": "skin", "newLayerId": "skin-copy", "name": "Skin Uniformity Copy" },
      { "type": "delete", "layerId": "tone" }
    ],
    "expectedLayers": [
      { "id": "skin", "name": "Skin Uniformity", "opacity": 65, "visible": true },
      { "id": "skin-copy", "name": "Skin Uniformity Copy", "opacity": 65, "visible": true }
    ]
  },
  {
    "id": "group-move-and-ungroup",
    "initialLayers": [
      { "id": "tone", "name": "Tone Balance", "opacity": 100, "visible": true },
      { "id": "skin", "name": "Skin Uniformity", "opacity": 65, "visible": true },
      { "id": "sky", "name": "Sky Recover", "opacity": 80, "visible": true }
    ],
    "operations": [
      { "type": "groupWithNext", "layerId": "skin", "groupId": "portrait-group", "groupName": "Portrait Group" },
      { "type": "moveGroup", "groupId": "portrait-group", "direction": "up" },
      { "type": "ungroup", "groupId": "portrait-group" }
    ],
    "expectedLayers": [
      { "id": "skin", "name": "Skin Uniformity", "opacity": 65, "visible": true },
      { "id": "sky", "name": "Sky Recover", "opacity": 80, "visible": true },
      { "id": "tone", "name": "Tone Balance", "opacity": 100, "visible": true }
    ]
  },
  {
    "id": "nested-group-blocked",
    "initialLayers": [
      {
        "id": "skin",
        "name": "Skin Uniformity",
        "opacity": 65,
        "visible": true,
        "layerGroupId": "portrait-group",
        "layerGroupName": "Portrait Group"
      },
      {
        "id": "sky",
        "name": "Sky Recover",
        "opacity": 80,
        "visible": true,
        "layerGroupId": "portrait-group",
        "layerGroupName": "Portrait Group"
      },
      { "id": "tone", "name": "Tone Balance", "opacity": 100, "visible": true }
    ],
    "operations": [
      { "type": "groupWithNext", "layerId": "skin", "groupId": "nested-group", "groupName": "Nested Group" }
    ],
    "expectedError": "nested and non-adjacent groups are blocked",
    "expectedLayers": [
      {
        "id": "skin",
        "name": "Skin Uniformity",
        "opacity": 65,
        "visible": true,
        "layerGroupId": "portrait-group",
        "layerGroupName": "Portrait Group"
      },
      {
        "id": "sky",
        "name": "Sky Recover",
        "opacity": 80,
        "visible": true,
        "layerGroupId": "portrait-group",
        "layerGroupName": "Portrait Group"
      },
      { "id": "tone", "name": "Tone Balance", "opacity": 100, "visible": true }
    ]
  }
]
