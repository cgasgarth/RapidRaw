{
  "id": "layer-stack-undo-redo-reorder-opacity-visibility",
  "initialLayers": [
    { "id": "tone", "name": "Tone Balance", "opacity": 100, "visible": true },
    { "id": "skin", "name": "Skin Uniformity", "opacity": 65, "visible": true },
    { "id": "sky", "name": "Sky Recover", "opacity": 80, "visible": true }
  ],
  "steps": [
    {
      "label": "hide skin layer",
      "operation": { "type": "setVisibility", "layerId": "skin", "visible": false }
    },
    {
      "label": "lower sky opacity",
      "operation": { "type": "setOpacity", "layerId": "sky", "opacity": 42 }
    },
    {
      "label": "move sky above skin",
      "operation": { "type": "move", "layerId": "sky", "direction": "up" }
    }
  ],
  "expectedFinalLayers": [
    { "id": "tone", "name": "Tone Balance", "opacity": 100, "visible": true },
    { "id": "sky", "name": "Sky Recover", "opacity": 42, "visible": true },
    { "id": "skin", "name": "Skin Uniformity", "opacity": 65, "visible": false }
  ],
  "expectedUndoLayers": [
    { "id": "tone", "name": "Tone Balance", "opacity": 100, "visible": true },
    { "id": "skin", "name": "Skin Uniformity", "opacity": 65, "visible": false },
    { "id": "sky", "name": "Sky Recover", "opacity": 42, "visible": true }
  ],
  "expectedRedoLayers": [
    { "id": "tone", "name": "Tone Balance", "opacity": 100, "visible": true },
    { "id": "sky", "name": "Sky Recover", "opacity": 42, "visible": true },
    { "id": "skin", "name": "Skin Uniformity", "opacity": 65, "visible": false }
  ]
}
