{
  "name": "rapidraw",
  "author": "Timon Käch",
  "private": true,
  "packageManager": "bun@1.3.13",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "tauri": "tauri",
    "start": "tauri dev",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "hooks:install": "git config core.hooksPath .githooks",
    "hooks:verify": "test \"$(git config --get core.hooksPath)\" = \".githooks\"",
    "hooks:check-staged": "bun scripts/check-staged-files.mjs",
    "check": "bun run check:quick && bun run check:bundle",
    "check:quick": "bun run check:types && bun run check:i18n && bun run check:unsafe-casts && bun run check:film-fixtures && bun run check:release-notes && bun run check:ai-fallbacks",
    "check:types": "tsc --noEmit --pretty false",
    "check:i18n": "i18next-cli extract --ci --dry-run",
    "check:unsafe-casts": "bun scripts/check-unsafe-casts.mjs",
    "check:ai-fallbacks": "bun scripts/check-ai-provider-fallbacks.mjs",
    "check:generated-types": "bun scripts/check-generated-type-drift.mjs",
    "check:film-fixtures": "bun scripts/check-film-look-fixture-outputs.mjs",
    "check:film-fixtures:update": "bun scripts/check-film-look-fixture-outputs.mjs --update",
    "check:panorama-fixtures": "bun scripts/check-panorama-fixture-manifest.mjs",
    "check:panorama-performance-fixtures": "bun scripts/check-panorama-performance-fixtures.mjs",
    "check:panorama-parity": "bun scripts/check-panorama-synthetic-parity.mjs",
    "check:hdr-alignment-smoke": "bun scripts/check-hdr-alignment-smoke.mjs",
    "check:hdr-deghosting-smoke": "bun scripts/check-hdr-deghosting-smoke.mjs",
    "check:hdr-merge-weighting-smoke": "bun scripts/check-hdr-merge-weighting-smoke.mjs",
    "check:focus-fixtures": "bun scripts/check-focus-synthetic-fixtures.mjs",
    "check:focus-fixtures:update": "bun scripts/check-focus-synthetic-fixtures.mjs --update",
    "check:focus-alignment-smoke": "bun scripts/check-focus-translation-alignment-smoke.mjs",
    "check:sr-performance-fixtures": "bun scripts/check-super-resolution-performance-fixtures.mjs",
    "check:lint-escapes": "bun scripts/check-eslint-escape-hatches.mjs",
    "check:lint": "eslint . --max-warnings 0",
    "check:format": "prettier --check .",
    "check:actions": "bun run check:actions:lint && bun run check:workflow-policy && bun run check:workflow-policy:self-test && bun run check:rust-feature-policy",
    "check:actions:lint": "go run github.com/rhysd/actionlint/cmd/actionlint@v1.7.12 .github/workflows/*.yml",
    "check:workflow-policy": "bun scripts/check-github-workflow-policy.mjs",
    "check:workflow-policy:self-test": "bun scripts/check-github-workflow-policy.mjs --self-test",
    "check:rust-feature-policy": "bun scripts/check-rust-feature-policy.mjs",
    "check:action-pins": "bun scripts/check-github-action-pins.mjs",
    "check:action-pins:latest": "bun scripts/check-github-action-pins.mjs --check-latest",
    "check:security": "bun run check:security:js && bun run check:security:rust",
    "check:security:js": "bun audit --audit-level moderate",
    "check:security:rust": "cd src-tauri && cargo audit --ignore RUSTSEC-2024-0429",
    "check:licenses": "bun run check:licenses:js && bun run check:licenses:rust",
    "check:licenses:js": "bun scripts/check-js-dependency-licenses.mjs",
    "check:licenses:rust": "cd src-tauri && cargo deny check licenses",
    "deps:audit": "bun scripts/audit-dependency-versions.mjs",
    "deps:audit:check": "bun scripts/audit-dependency-versions.mjs --fail-on-missing-major-issues",
    "deps:audit:js": "bun scripts/audit-dependency-versions.mjs --ecosystem=js",
    "deps:audit:rust": "bun scripts/audit-dependency-versions.mjs --ecosystem=rust",
    "check:performance-smoke": "bun scripts/check-performance-smoke.mjs",
    "check:visual-smoke": "bun scripts/capture-visual-smoke.mjs",
    "check:bundle": "bun run build:frontend && bun run check:bundle:budget",
    "check:bundle:budget": "bun scripts/check-vite-bundle-budget.mjs",
    "check:ci-paths": "bun scripts/ci-classify-macos-smoke.mjs --self-test",
    "check:sidecar-roundtrip": "bun scripts/check-sidecar-roundtrip.mjs",
    "check:docs": "bun run docs:check",
    "check:release-metadata": "bun scripts/generate-release-metadata.mjs --self-test",
    "release:notes": "bun scripts/generate-release-notes.mjs",
    "check:release-notes": "bun scripts/generate-release-notes.mjs --self-test",
    "check:rust": "bun run check:rust:fmt && bun run check:rust:check && bun run check:rust:clippy && bun run check:rust:test",
    "check:rust:fmt": "cd src-tauri && cargo fmt -p RapidRAW -- --check",
    "check:rust:check": "cd src-tauri && cargo check --locked --no-default-features --features required-ci",
    "check:rust:clippy": "cd src-tauri && cargo clippy --locked --all-targets --no-default-features --features required-ci -- -D warnings",
    "schema:check": "tsc -p packages/rawengine-schema/tsconfig.json --noEmit --pretty false && bun packages/rawengine-schema/scripts/check-samples.ts && bun run schema:samples",
    "schema:samples": "bun packages/rawengine-schema/scripts/check-sample-artifacts.mjs",
    "schema:samples:update": "bun packages/rawengine-schema/scripts/check-sample-artifacts.mjs --update",
    "check:rust:test": "cd src-tauri && cargo test --locked --all-targets --no-default-features --features required-ci --no-fail-fast",
    "build:frontend": "vite build",
    "docs:check": "prettier --check \"**/*.md\" && bun scripts/check-markdown-links.mjs",
    "i18n:extract": "i18next-cli extract",
    "i18n:check": "i18next-cli extract --ci --dry-run",
    "i18n:lint": "i18next-cli lint"
  },
  "dependencies": {
    "@clerk/react": "^6.9.1",
    "@dnd-kit/core": "^6.3.1",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-os": "^2.3.2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@uiw/color-convert": "^2.10.3",
    "@uiw/react-color-wheel": "^2.10.3",
    "clsx": "^2.1.1",
    "framer-motion": "^12.40.0",
    "i18next": "^26.3.1",
    "konva": "^10.3.0",
    "lodash.debounce": "^4.0.8",
    "lodash.throttle": "^4.1.1",
    "lucide-react": "^1.18.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-draggable": "^4.6.0",
    "react-i18next": "^17.0.8",
    "react-image-crop": "^11.0.10",
    "react-konva": "^19.2.5",
    "react-toastify": "^11.1.0",
    "react-window": "^2.2.7",
    "simple-icons": "^16.23.0",
    "uuid": "^14.0.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.3.1",
    "@tauri-apps/cli": "^2.11.1",
    "@types/lodash.debounce": "^4.0.9",
    "@types/lodash.throttle": "^4.1.9",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "esbuild": "^0.28.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-i18next": "^6.1.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "i18next-cli": "^1.63.1",
    "license-checker-rseidelsohn": "5.0.1",
    "prettier": "^3.8.4",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16"
  }
}
