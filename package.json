{
  "name": "rapidraw",
  "author": "Timon Käch",
  "private": true,
  "packageManager": "bun@1.3.13",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "tauri": "tauri",
    "start": "tauri dev",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "hooks:install": "git config core.hooksPath .githooks",
    "hooks:verify": "test \"$(git config --get core.hooksPath)\" = \".githooks\"",
    "check": "bun run check:quick && bun run check:bundle",
    "check:quick": "bun run check:types && bun run check:i18n && bun run check:unsafe-casts",
    "check:types": "tsc --noEmit --pretty false",
    "check:i18n": "i18next-cli extract --ci --dry-run",
    "check:unsafe-casts": "bun scripts/check-unsafe-casts.mjs",
    "check:lint": "eslint . --max-warnings 0",
    "check:format": "prettier --check .",
    "check:actions": "go run github.com/rhysd/actionlint/cmd/actionlint@v1.7.12 .github/workflows/*.yml",
    "check:action-pins": "node scripts/check-github-action-pins.mjs",
    "check:action-pins:latest": "node scripts/check-github-action-pins.mjs --check-latest",
    "check:bundle": "bun run build:frontend && bun run check:bundle:budget",
    "check:bundle:budget": "bun scripts/check-vite-bundle-budget.mjs",
    "check:ci-paths": "node scripts/ci-classify-macos-smoke.mjs --self-test",
    "check:release-metadata": "node scripts/generate-release-metadata.mjs --self-test",
    "check:rust": "bun run check:rust:fmt && bun run check:rust:check && bun run check:rust:clippy",
    "check:rust:fmt": "cd src-tauri && cargo fmt -p RapidRAW -- --check",
    "check:rust:check": "cd src-tauri && cargo check",
    "check:rust:clippy": "cd src-tauri && cargo clippy --all-targets --all-features -- -D warnings",
    "build:frontend": "vite build",
    "i18n:extract": "i18next-cli extract",
    "i18n:check": "i18next-cli extract --ci --dry-run",
    "i18n:lint": "i18next-cli lint"
  },
  "dependencies": {
    "@clerk/react": "^6.6.2",
    "@dnd-kit/core": "^6.3.1",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-os": "^2.3.2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@uiw/color-convert": "^2.10.1",
    "@uiw/react-color-wheel": "^2.10.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "i18next": "^26.3.0",
    "konva": "^10.3.0",
    "lodash.debounce": "^4.0.8",
    "lodash.throttle": "^4.1.1",
    "lucide-react": "^1.14.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-draggable": "^4.5.0",
    "react-i18next": "^17.0.8",
    "react-image-crop": "^11.0.10",
    "react-konva": "^19.2.4",
    "react-toastify": "^11.1.0",
    "react-window": "^2.2.7",
    "simple-icons": "^16.19.0",
    "uuid": "^14.0.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/cli": "^2.11.1",
    "@types/lodash.debounce": "^4.0.9",
    "@types/lodash.throttle": "^4.1.9",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-i18next": "^6.1.4",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "i18next-cli": "^1.58.0",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.59.3",
    "vite": "^8.0.12"
  }
}
