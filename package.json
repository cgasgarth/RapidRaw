    "docs:check": "prettier --check \"**/*.md\" && bun scripts/check-markdown-links.mjs",
    "i18n:extract": "i18next-cli extract",
    "i18n:check": "i18next-cli extract --ci --dry-run",
    "i18n:lint": "i18next-cli lint"
